{
    "workbench.startupEditor": "none",
    "editor.fontFamily": "'liga Mononoki', 'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
    "editor.fontSize": 13,
    "workbench.sideBar.location": "right",
    "telemetry.telemetryLevel": "off",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "workbench.iconTheme": "vscode-icons",
    "vsicons.dontShowNewVersionMessage": true,
    "editor.quickSuggestions": true,
    "notebook.lineNumbers": "on",
    "breadcrumbs.enabled": false,
    "editor.wordWrap": "on",
    "git-graph.maxDepthOfRepoSearch": 1,
    "httpyac.codelens": {
        "clearHistory": true,
        "showResponseHeaders": true,
        "showVariables": true
    },
    "httpyac.environmentShowStatusBarItem": true,
    "httpyac.environmentStatusBarItemDefaultBackground": "warning",
    "httpyac.environmentStoreSelectedOnStart": true,
    "httpyac.responseViewColumn": "current",
    "debug.terminal.clearBeforeReusing": true,
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.defaultLocation": "editor",
    "terminal.integrated.scrollback": 2000,
    "terminal.integrated.defaultProfile.linux": "bash",
    "[python]": {
        "editor.defaultFormatter": "ms-python.python"
    },
    "python.formatting.provider": "black",
    "python.linting.pylintEnabled": true,
    "python.linting.flake8Enabled": true,
    "python.linting.pycodestyleArgs": [
        "--ignore=E501", "--max-line-length=120"
    ],
    "python.linting.flake8Args": [
        "--ignore=E501",
        "--verbose"
    ],
    "open-in-browser.default": "brave-browser",
    "gitlens.views.repositories.showContributors": false,
    "python.linting.enabled": true,
    "gitlens.views.repositories.showBranchComparison": false,
    "gitlens.views.repositories.showCommits": false,
    "gitlens.views.repositories.showTags": false,
    "gitlens.views.repositories.showRemotes": false,
    "workbench.editor.wrapTabs": true,
    "gitlens.views.commits.showBranchComparison": false,
    "debug.console.fontSize": 13,
    "terminal.integrated.fontSize": 13,
    "markdown.preview.fontSize": 13,
    "gitlens.views.commits.avatars": false,
    "gitlens.views.fileHistory.avatars": false,
    "gitlens.views.branches.avatars": false
}
