#!/bin/sh

# WM
# -------------
exec fluxbox &
fbpid=$!

sleep 0.1
{
    # APPLICATIONS
    # -------------
    dunst &
    skippy-xd --config ~/.config/skyppy-xd/skippy-xd.rc --start-daemon &
    netwmpager &
    fittstool &
    conky -c ~/.config/conky/inforc &
    conky -c ~/.config/conky/authnetrc &

    # APPLETS
    # -------------
    # redshift-gtk &
    clipit &
    nm-applet &
    blueman-applet &
    volumeicon &
} &

wait $fbpid
